{
  "name": "halo-cheats-storefront",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node server.js",
    "dev:web": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "stripe:setup": "node scripts/setup-stripe-catalog.mjs",
    "start": "node server.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.56.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
"cors": "^2.8.5",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "stripe": "^18.5.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "vite": "^7.1.0"
  }
}
