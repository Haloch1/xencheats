# Two-way live support: parent channel where site tickets open a Discord thread.
# Required for staff to answer tickets from Discord. Leave blank to disable.
DISCORD_SUPPORT_CHANNEL_ID=
# Role granted to repeat buyers (2+ fulfilled orders). Has a built-in default.
DISCORD_REPEAT_BUYER_ROLE_ID=

# Promo codes (optional). Comma-separated CODE:percent pairs. Leave unset to
# disable all promos. Set the real value in Render, never commit real codes.
# Example: PROMO_CODES=HALO10:10,R6SAVE:15
PROMO_CODES=

# Groq model for the Discord AI bot and search. Optional — defaults to
# openai/gpt-oss-20b. Only set this to override the default.
GROQ_MODEL=

