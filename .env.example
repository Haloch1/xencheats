# Verification fraud controls. Generate a random 32+ byte value for the hash
# secret. Run supabase-discord-verification-security.sql before setting REQUIRE
# SECURITY TABLES to true. Policies: allow, review, or block.
DISCORD_VERIFICATION_IP_HASH_SECRET=
DISCORD_VERIFICATION_REQUIRE_SECURITY_TABLES=false
DISCORD_VERIFICATION_IP_REUSE_POLICY=review
DISCORD_VERIFICATION_PROXY_POLICY=review
# Optional IPQualityScore API key for VPN/proxy detection.
